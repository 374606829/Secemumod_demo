# ============================================================
# Secemumod Demo — Environment Variables
# Copy to .env for Docker: cp .env.example .env
# ============================================================

# Database (Docker Compose uses these)
DB_USERNAME=root
DB_PASSWORD=root

# JWT Secret (change in production)
JWT_SECRET=ThisIsADemoSecretKeyForMVPPurposeOnly2024abcdefghijk

# Encryption MasterKey (Base64, must decode to 32 bytes)
ENCRYPTION_MASTER_KEY=cGxlYXNlQ2hhbmdlTWVJbkpKaW9uQXVnVUtWYWx1ZQA=

# Mod file storage path (local run only)
MOD_STORAGE_PATH=./storage/mods
